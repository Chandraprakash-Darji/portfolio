---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { postTransitionName } from '../../lib/transition';

const posts = await getCollection('snippets');
const sorted = posts
  .filter((p) => p.data.published !== false)
  .toSorted((a, b) => b.data.publishedAt?.localeCompare(a.data.publishedAt ?? '') ?? 0);
---

<BaseLayout
  title="Snippets"
  description="Short code snippets I find useful."
  ogImage="snippet"
>
  <div class="layout py-16">
    <a href="/" class="mb-8 flex items-center gap-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground">
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5m7-7-7 7 7 7" />
      </svg>
      home
    </a>
    <h1 class="text-2xl font-medium tracking-tight">Snippets</h1>
    <p class="mt-2 text-muted-foreground">
      Short code snippets I find useful.
    </p>
    <div class="mt-10 w-full">
      {sorted.map((post) => {
        const date = post.data.publishedAt ?? post.data.updatedAt ?? '';
        const slug = post.id.replace(/\.mdx$/, '');
        return (
          <a
            href={`/writing/${slug}`}
            class="group flex items-center justify-between gap-4 border-b border-border px-1 py-2 font-mono text-xs text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground last:border-0 -mx-1 rounded"
          >
            <span class="min-w-0 truncate">
              <span class="text-muted-foreground/60">{date}</span>{' '}
              <span style={`view-transition-name: ${postTransitionName(post.data.title)}`} class="font-medium text-foreground">{post.data.title}</span>
            </span>
            <svg class="h-3 w-3 shrink-0 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14m-7-7 7 7-7 7" />
            </svg>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
