---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents';
import ReadingProgress from '../../components/ReadingProgress';
import CustomLink from '../../components/links/CustomLink';
import { PostHeader } from '../../components/content/PostHeader';
import { Pre } from '../../components/content/Pre';
import { postTransitionName } from '../../lib/transition';
import { siteConfig } from '../../site.config';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const snippetPosts = await getCollection('snippets');
  const all = [...blogPosts, ...snippetPosts];
  return all
    .filter((p) => p.data.published !== false)
    .map((entry) => ({
      params: { slug: entry.id.replace(/\.mdx$/, '') },
    }));
}

const { slug } = Astro.params;
const blogPosts = await getCollection('blog');
const snippetPosts = await getCollection('snippets');
const entry = [...blogPosts, ...snippetPosts].find(
  (p) => p.id.replace(/\.mdx$/, '') === slug
);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content, headings:pageHeadings } = await render(entry);

const { title, description, publishedAt, updatedAt, categories = [] } = entry.data;
const date = updatedAt ?? publishedAt ?? '';
const readingTime = Math.max(1, Math.round((entry.body?.split(/\s+/).length ?? 0) / 200));
const isSnippet = entry.collection === 'snippets';
const backHref = isSnippet ? '/snippet' : '/writing';
const backLabel = isSnippet ? 'snippets' : 'writing';

const allPosts = [...blogPosts, ...snippetPosts].filter((p) => p.data.published !== false);
const relatedPosts = allPosts
  .filter((p) => {
    if (p.id === entry.id) return false;
    const pCats = (p.data.categories ?? []).map((c) => c.slug).filter(Boolean) as string[];
    const entryCats = new Set(categories.map((c) => c.slug).filter(Boolean) as string[]);
    return pCats.some((c) => entryCats.has(c));
  })
  .toSorted((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''))
  .slice(0, 2);

// prev/next: sorted same-collection posts by publishedAt desc
const sameCollectionPosts = [...blogPosts, ...snippetPosts]
  .filter((p) => p.collection === entry.collection && p.data.published !== false)
  .toSorted((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''));
const currentIndex = sameCollectionPosts.findIndex((p) => p.id === entry.id);
const previous = currentIndex > 0
  ? { slug: sameCollectionPosts[currentIndex - 1].id.replace(/\.mdx$/, ''), title: sameCollectionPosts[currentIndex - 1].data.title }
  : null;
const next = currentIndex < sameCollectionPosts.length - 1
  ? { slug: sameCollectionPosts[currentIndex + 1].id.replace(/\.mdx$/, ''), title: sameCollectionPosts[currentIndex + 1].data.title }
  : null;

const collectionPath = isSnippet ? 'snippets' : 'blog';
const gitHubEditUrl = `https://github.com/Chandraprakash-Darji/portfolio/blob/main/src/content/${collectionPath}/${entry.id}.mdx`;
const markdownUrl = `${siteConfig.url}/${isSnippet ? 'snippet' : 'writing'}/${slug}.md`;
const postUrl = `${siteConfig.url}/${isSnippet ? 'snippet' : 'writing'}/${slug}`;

---

<BaseLayout
  title={title}
  description={description}
  ogImage={`writing/${slug}`}
>
  <ReadingProgress client:load />
  <div class="mx-auto w-11/12 max-w-2xl py-10">
    <PostHeader
      client:load
      markdownUrl={markdownUrl}
      githubUrl={gitHubEditUrl}
      postUrl={postUrl}
      postTitle={title}
      backHref={backHref}
      backLabel={backLabel}
      previous={previous}
      next={next}
    />

    <section class="flex flex-col gap-3 pt-4">
      <h1 transition:name={postTransitionName(title)} class="text-2xl font-medium leading-snug tracking-tight">{title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 font-mono text-xs text-muted-foreground">
        <span class="flex items-center gap-1">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
          </svg>
          {date}
        </span>
        <span aria-hidden="true">·</span>
        <span class="flex items-center gap-1">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
          </svg>
          {readingTime} min
        </span>
        {categories.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <div class="flex flex-wrap gap-1.5">
              {categories.map((c) => (
                <span class="rounded border border-border px-1.5 py-0.5 text-xs text-muted-foreground">
                  {c.name}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </section>

    {description && (
      <p class="mt-4 text-muted-foreground">{description}</p>
    )}

    <TableOfContents headings={pageHeadings} client:load />

    <article class="lg:prose-md prose dark:prose-invert relative w-full max-w-none py-4 prose-a:no-underline">
      <Content components={{ pre: Pre, a: CustomLink }} />
    </article>

    <footer class="mt-10 pt-6 text-right font-mono text-sm text-muted-foreground">
      — {siteConfig.author.name}
    </footer>

    <hr class="mt-10 border-border" />

    <div class="mt-6 flex flex-col gap-6">
      <a
        href={gitHubEditUrl}
        class="inline-flex items-center gap-1.5 font-mono text-xs text-muted-foreground hover:text-foreground transition-colors w-fit"
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
        </svg>
        edit on github
      </a>

      {relatedPosts.length > 0 && (
        <div class="mt-6">
          <span class="font-mono text-xs text-muted-foreground/60 uppercase tracking-widest">read next</span>
          <div class="mt-3 flex flex-col gap-2">
            {relatedPosts.map((p) => {
              const pSlug = p.id.replace(/\.mdx$/, '');
              return (
                <a
                  href={`/writing/${pSlug}`}
                  class="group flex items-center justify-between gap-4 border-b border-border px-1 py-2 font-mono text-xs text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground last:border-0 -mx-1 rounded"
                >
                  <span class="min-w-0 truncate">
                    <span class="text-muted-foreground/60">{p.data.publishedAt?.slice(0, 7).replace('-', '/')}</span>{' '}
                    {p.data.title}
                  </span>
                  <svg class="h-3 w-3 shrink-0 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14m-7-7 7 7-7 7" />
                  </svg>
                </a>
              );
            })}
          </div>
        </div>
      )}

      <div class="mt-8" id="giscus-container">
        <script is:inline>
          const isDark = document.documentElement.classList.contains('dark');
          const script = document.createElement('script');
          script.src = 'https://giscus.app/client.js';
          script.setAttribute('data-repo', 'Chandraprakash-Darji/portfolio');
          script.setAttribute('data-repo-id', 'R_kgDOLTT4QA');
          script.setAttribute('data-category', 'General');
          script.setAttribute('data-category-id', 'DIC_kwDOLTT4QM4CdTNt');
          script.setAttribute('data-mapping', 'pathname');
          script.setAttribute('data-strict', '0');
          script.setAttribute('data-reactions-enabled', '1');
          script.setAttribute('data-emit-metadata', '0');
          script.setAttribute('data-input-position', 'bottom');
          script.setAttribute('data-theme', isDark ? 'dark_dimmed' : 'light');
          script.setAttribute('data-lang', 'en');
          script.setAttribute('data-loading', 'lazy');
          script.crossOrigin = 'anonymous';
          script.async = true;
          document.getElementById('giscus-container').appendChild(script);

          // listen for theme changes and update giscus
          const observer = new MutationObserver(() => {
            const dark = document.documentElement.classList.contains('dark');
            const iframe = document.querySelector('iframe.giscus-frame');
            if (iframe) {
              iframe.contentWindow?.postMessage(
                { giscus: { setConfig: { theme: dark ? 'dark_dimmed' : 'light' } } },
                'https://giscus.app'
              );
            }
          });
          observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

        </script>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('article pre').forEach((pre) => {
      if (pre.closest('.code-block-wrapper')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper group relative';

      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const actions = document.createElement('div');
      actions.className = 'code-actions absolute right-2 top-2 z-20 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity';

      const wrapBtn = document.createElement('button');
      wrapBtn.className = 'rounded border border-border bg-background p-1 text-xs text-muted-foreground hover:text-foreground transition-colors md:hidden';
      let wrapped = false;
      wrapBtn.textContent = 'wrap';
      wrapBtn.addEventListener('click', () => {
        wrapped = !wrapped;
        if (wrapped) {
          pre.classList.add('!whitespace-pre-wrap');
          pre.classList.remove('!whitespace-pre');
          wrapBtn.textContent = 'unwrap';
        } else {
          pre.classList.remove('!whitespace-pre-wrap');
          wrapBtn.textContent = 'wrap';
        }
      });

      const copyBtn = document.createElement('button');
      copyBtn.className = 'rounded border border-border bg-background p-1 text-xs text-muted-foreground hover:text-foreground transition-colors';
      copyBtn.textContent = 'copy';
      copyBtn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(pre.querySelector('code')?.textContent ?? '');
        copyBtn.textContent = 'copied';
        setTimeout(() => (copyBtn.textContent = 'copy'), 1500);
      });

      actions.appendChild(wrapBtn);
      actions.appendChild(copyBtn);
      wrapper.appendChild(actions);
    });
  });
</script>
