---
import BaseLayout from '../layouts/BaseLayout.astro';
import WritingSection from '../components/WritingSection.astro';
import ArrowLink from '../components/links/ArrowLink';
import { siteConfig } from '../site.config';
---

<BaseLayout
  ogImage="home"
>
  <div class="layout space-y-16 py-20">
    <!-- Hero -->
    <section>
      <img
        src="https://github.com/Chandraprakash-Darji.png"
        alt="Chandraprakash Darji"
        width="80"
        height="80"
        class="mb-4 rounded-full"
      />
      <h1 class="text-2xl font-medium tracking-tight">
        {siteConfig.author.name}
      </h1>
      <p class="mt-2 max-w-xl text-muted-foreground">
        Full-stack developer obsessed with scalable systems and clean architecture.
        I design backends that hold up under load, pick the right tool for the job,
        and write about the decisions that actually matter in production.
      </p>
      <ul class="mt-4 space-y-1 text-sm text-muted-foreground">
        <li>
          <strong class="text-foreground">Systems thinking</strong>
          &mdash; I care about how the pieces fit — queues, services, data flow, failure modes.
        </li>
        <li>
          <strong class="text-foreground">Right tool, right scale</strong>
          &mdash; No Kafka at 10 users. No monolith at 10 million. I match architecture to the actual problem.
        </li>
        <li>
          <strong class="text-foreground">Ship and iterate</strong>
          &mdash; Good architecture is the one that lets you move fast now and change your mind later.
        </li>
      </ul>
    </section>

    <!-- Writing -->
    <section>
      <div class="mb-1 flex items-center justify-between">
        <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
          Writing
        </span>
        <ArrowLink href="/writing" className="font-mono text-xs text-muted-foreground hover:text-foreground">
          all posts
        </ArrowLink>
      </div>
      <WritingSection collection="blog" />
    </section>

    <!-- Snippets -->
    <section>
      <div class="mb-1 flex items-center justify-between">
        <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
          Snippets
        </span>
        <ArrowLink href="/snippet" className="font-mono text-xs text-muted-foreground hover:text-foreground">
          all snippets
        </ArrowLink>
      </div>
      <WritingSection collection="snippets" />
    </section>
  </div>
</BaseLayout>
