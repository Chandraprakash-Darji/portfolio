---
import { getCollection } from 'astro:content';
import { postTransitionName } from '../lib/transition';

interface Props {
  collection: 'blog' | 'snippets';
}

const { collection } = Astro.props;
const posts = await getCollection(collection);
const recent = posts
  .filter((p) => p.data.published !== false)
  .toSorted((a, b) => b.data.publishedAt?.localeCompare(a.data.publishedAt ?? '') ?? 0)
  .slice(0, 3);
---

<div class="w-full">
  {recent.map((post) => {
    const date = post.data.publishedAt ?? post.data.updatedAt ?? '';
    const slug = post.id.replace(/\.mdx$/, '');
    return (
      <a
        href={`/writing/${slug}`}
        class="group flex items-center justify-between gap-4 border-b border-border px-1 py-2 font-mono text-xs text-muted-foreground transition-colors hover:bg-muted/40 hover:text-foreground last:border-0 -mx-1 rounded"
      >
        <span class="min-w-0 truncate">
          <span class="text-muted-foreground/60">{date}</span>{' '}
          <span style={`view-transition-name: ${postTransitionName(post.data.title)}`} class="font-medium text-foreground transition-colors group-hover:text-foreground">{post.data.title}</span>
        </span>
        <svg class="h-3 w-3 shrink-0 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14m-7-7 7 7-7 7" />
        </svg>
      </a>
    );
  })}
</div>
