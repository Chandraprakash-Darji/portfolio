generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider = "npx zod-prisma"
  output   = "./../src/lib/zod"
  imports  = "./../src/lib/zod-utils"
}

generator enums {
  provider = "tsx ./src/lib/enum-generator"
  output   = "./../src/lib/enums"
}

model App {
  id              String   @id @default(cuid()) /// @zod.cuid()
  maintenanceMode Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid()) /// @zod.cuid()
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(cuid()) /// @zod.cuid()
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid()) /// @zod.cuid()
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid()) /// @zod.cuid()
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id     String @id @default(cuid()) /// @zod.cuid()
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model User {
  id                    String                 @id @default(cuid()) /// @zod.cuid()
  createdAt             DateTime               @default(now())
  name                  String
  email                 String                 @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  UserRole               @default(USER)
  accounts              Account[]
  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorConfirmation TwoFactorConfirmation?

  /// @zod.custom(imports.userMetadataSchema)
  metadata Json?

  posts    Post[]
  comments Comment[]
  likedPost Like[]
  shared  Share[]
}

enum UserRole {
  ADMIN
  USER
}

model Post {
  id            String     @id @default(cuid()) /// @zod.cuid()
  title         String /// @zod.min(2).max(120)
  description   String? /// @zod.min(2).max(300)
  content       String?
  slug          String     @unique /// @zod.min(2).max(100)
  image         String     @default("https://ik.imagekit.io/jrbttakyqa/portfolio/empty.png")
  imageBlurhash String     @default("data:image/png;base64,")
  createdAt     DateTime   @default(now()) @db.Timestamp(6)
  updatedAt     DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  published     Boolean    @default(false)
  userId        String
  type          PostType   @default(BLOG)
  views         Int?       @default(0)
  likes         Like[]
  categories    Category[]
  comments      Comment[]
  shares        Share[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "posts_userId_index")
}

enum PostType {
  BLOG
  SNIPPET
}

model Category {
  id    String @id @default(cuid()) /// @zod.cuid()
  name  String
  slug  String
  color String @default("0,0,100")
  posts Post[]
}

model Comment {
  id         String   @id @default(cuid()) /// @zod.cuid() 
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  content    String /// @zod.min(3).max(500)
  email      String?
  likes      Int?     @default(0)
  isApproved Boolean  @default(false)
  parentId   String?

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  replies       Comment[] @relation("CommentReplies")
  parentComment Comment?  @relation("CommentReplies", fields: [parentId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}

model Like {
  id     String @id @default(cuid()) /// @zod.cuid()
  userId String?
  postId String

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum ShareType {
  FACEBOOK
  X
  LINKEDIN
  EMAIL
  COPY
}

model Share {
  id        String    @id @default(cuid()) /// @zod.cuid()
  type      ShareType
  postId    String
  userId    String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}